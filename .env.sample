# -----------------------------------------------------------------------------
# CodeCompanion / Neovim local environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` (same directory) and edit. `.env` is gitignored so
# your per-machine choices never land in version control; this sample IS tracked.
#
#   cp .env.sample .env
#
# Format: KEY=VALUE, one per line. `#` starts a full-line comment. Values may be
# quoted. Loaded at startup by lua/config/env.lua. Anything already exported by
# your shell (e.g. ~/.zshrc.secrets) wins over this file.
#
# Full reference for every variable below:
#   docs/plugins/codecompanion/env-vars.md
# -----------------------------------------------------------------------------

# Default adapter for chat + inline. Unset falls back to claude_proxy. Names:
#   claude_proxy   Claude via proxy URL, else api.anthropic.com
#   openai         GPT via an OpenAI-compatible proxy (Responses API)
#   deepseek       DeepSeek direct (needs DEEPSEEK_API_KEY)
#   anthropic      Anthropic direct (needs ANTHROPIC_API_KEY)
#   ollama_qwen    Local Ollama (qwen2.5-coder)
#   claude_code    Claude Code over ACP (Claude Pro/Max subscription). CHAT ONLY.
#   pi             Pi coding agent over ACP. CHAT ONLY.
# ACP adapters (claude_code, pi) need optional bridges -- see
# docs/plugins/codecompanion/prerequisites.md and acp-support.md.
# CC_DEFAULT_ADAPTER=deepseek

# Override the model within the chosen adapter (must be one it knows). For
# claude_code use the Claude Code form: opus (or sonnet).
# CC_DEFAULT_MODEL=deepseek-v4-pro

# Background chat-title generation (separate cheap request). Defaults to
# claude_proxy/haiku; point it at a provider you have balance with.
# CC_TITLE_ADAPTER=deepseek
# CC_TITLE_MODEL=deepseek-v4-flash

# Inline (:CodeCompanion) requires an HTTP adapter. Unset, it follows the chat
# default while that is HTTP, else falls back to claude_proxy. Override:
# CC_INLINE_ADAPTER=deepseek
# CC_INLINE_MODEL=deepseek-v4-pro

# ACP bridge binaries, if not on the PATH Neovim inherits (both are node
# scripts, so node must be too). CC_PI_ACP_CMD may point at an `npx -y pi-acp`
# wrapper to always load the latest bridge.
# CC_CLAUDE_ACP_CMD=/home/you/.npm-global/bin/claude-agent-acp
# CC_PI_ACP_CMD=/home/you/.npm-global/bin/pi-acp

# -- Proxy endpoints (usually exported by the shell; listed here for docs) --
# OPENAI_COMPAT_PROXY_URL=
# OPENAI_RESPONSES_PROXY_URL=
# CLAUDE_PROXY_URL=
# CLAUDE_PROXY_API_KEY_CMD=

# -- Direct-provider keys (prefer ~/.zshrc.secrets; here only if you must) --
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
