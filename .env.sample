# -----------------------------------------------------------------------------
# CodeCompanion / Neovim local environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` (same directory) and edit. `.env` is gitignored so
# your per-machine choices never land in version control; this sample IS tracked
# and documents what each variable does.
#
#   cp .env.sample .env
#
# Format: KEY=VALUE, one per line. `#` starts a full-line comment. Values may be
# quoted. It is loaded at startup by lua/config/env.lua.
#
# Precedence: anything already exported by your shell (e.g. ~/.zshrc.secrets)
# wins over this file, so an environment that already exports these keeps working
# untouched.
# -----------------------------------------------------------------------------

# Default adapter for CodeCompanion chat + inline interactions.
# Leave unset to keep the built-in default. Adapters are defined in
# lua/plugins/codecompanion.lua; by name:
#   claude_proxy   Claude via proxy URL, else api.anthropic.com
#   openai         GPT via an OpenAI-compatible proxy (Responses API)
#   deepseek       DeepSeek direct (needs DEEPSEEK_API_KEY)
#   anthropic      Anthropic direct (needs ANTHROPIC_API_KEY)
#   ollama_qwen    Local Ollama (qwen2.5-coder)
# CC_DEFAULT_ADAPTER=deepseek

# Optional: override the default model within the chosen adapter. Must be a model
# the adapter knows (see its schema.model.choices). Leave unset to use the
# adapter's own default. Example for deepseek (v4-pro = most capable):
# CC_DEFAULT_MODEL=deepseek-v4-pro

# Chat-history title generation is a separate cheap background request. By
# default it uses claude_proxy/haiku; override it to a provider you have balance
# with (otherwise failed title requests spam errors). Example:
# CC_TITLE_ADAPTER=deepseek
# CC_TITLE_MODEL=deepseek-v4-flash

# -- Proxy endpoints (usually exported by the shell; listed here for docs) --
# OPENAI_COMPAT_PROXY_URL=
# OPENAI_RESPONSES_PROXY_URL=
# CLAUDE_PROXY_URL=
# CLAUDE_PROXY_API_KEY_CMD=

# -- Direct-provider keys (prefer ~/.zshrc.secrets; here only if you must) --
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
